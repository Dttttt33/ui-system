{
  "$schema": "farm-ring-toss-design-tokens/1.0",
  "meta": {
    "name": "Farm Ring Toss",
    "theme": "cartoon-farm",
    "style_ref": "Cartoon Games GUI Pack — green/amber/cream layered panels",
    "target": "casual-female-beginner",
    "display": "16:9 landscape, TV/projector, standing 1.5m away"
  },

  "color": {
    "brand": {
      "green": "#6EC531",
      "green-dark": "#4A9B1E",
      "green-deep": "#2B5E10",
      "amber": "#F5A623",
      "amber-dark": "#D4891A",
      "amber-deep": "#A06810",
      "red": "#E8453A",
      "red-dark": "#C43028",
      "red-deep": "#8B1A14"
    },
    "surface": {
      "panel-fill": "#FFF5D6",
      "panel-inner": "#FFF9E8",
      "panel-border": "#D4A84B",
      "panel-border-deep": "#A07830",
      "card-row": "#F5E8C0",
      "page-bg": "#87CEEB",
      "grass": "#6EC531",
      "overlay": "rgba(0,0,0,0.5)"
    },
    "semantic": {
      "success": "#6EC531",
      "perfect": "#FFD700",
      "miss": "#C4B898",
      "combo": "#E8453A",
      "warning": "#F5A623",
      "info": "#4A9DD9",
      "locked": "#8B8B8B"
    },
    "game": {
      "ring-normal": "#F5A623",
      "ring-precision": "#4A9DD9",
      "ring-shockwave": "#E8453A",
      "charge-empty": "#D4C9A8",
      "charge-fill": "#6EC531",
      "charge-full": "#FFD700",
      "target-crop": "#6EC531",
      "target-animal": "#F5C87A",
      "target-golden": "#FFD700",
      "target-rainbow": "linear-gradient(135deg, #E8453A, #FFD700, #6EC531, #4A9DD9)"
    },
    "text": {
      "dark": "#4A3728",
      "medium": "#6B5540",
      "light": "#8B7A60",
      "on-green": "#FFFFFF",
      "on-amber": "#4A3728",
      "on-red": "#FFFFFF",
      "on-panel": "#4A3728",
      "hud": "#FFFFFF"
    }
  },

  "typography": {
    "family": {
      "display": "'Luckiest Guy', cursive",
      "body": "'Fredoka', 'Nunito', sans-serif",
      "hud": "'Luckiest Guy', cursive"
    },
    "scale": {
      "hud-score": { "size": "64px", "weight": 400, "line-height": 1.0, "letter-spacing": "2px" },
      "hud-combo": { "size": "52px", "weight": 400, "line-height": 1.0 },
      "hud-label": { "size": "22px", "weight": 400, "line-height": 1.2 },
      "display-lg": { "size": "44px", "weight": 400, "line-height": 1.1 },
      "display-md": { "size": "32px", "weight": 400, "line-height": 1.2 },
      "title": { "size": "24px", "weight": 400, "line-height": 1.3 },
      "body": { "size": "18px", "weight": 500, "line-height": 1.5, "family": "body" },
      "caption": { "size": "14px", "weight": 500, "line-height": 1.4, "family": "body" },
      "micro": { "size": "11px", "weight": 600, "line-height": 1.2, "family": "body" }
    },
    "effect": {
      "outline-dark": "-1px -1px 0 #4A3728, 1px -1px 0 #4A3728, -1px 1px 0 #4A3728, 1px 1px 0 #4A3728",
      "shadow-hard": "0 3px 0 rgba(0,0,0,0.3)",
      "shadow-green": "0 2px 0 #357A12",
      "glow-gold": "0 0 8px rgba(255,215,0,0.6)"
    }
  },

  "spacing": {
    "unit": 8,
    "scale": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px",
      "3xl": "64px"
    },
    "layout": {
      "hud-margin": "24px",
      "hud-gap": "12px",
      "panel-padding": "20px",
      "panel-inner-padding": "16px",
      "screen-safe-area": "40px"
    }
  },

  "radius": {
    "sm": "8px",
    "md": "14px",
    "lg": "20px",
    "xl": "28px",
    "pill": "999px",
    "circle": "50%",
    "panel": "24px",
    "button": "14px"
  },

  "depth": {
    "_comment": "No drop-shadow. Depth = thick border + bottom bar + inner highlight + surface shine.",
    "panel": {
      "border": "4px solid var(--panel-border)",
      "bottom-bar": "0 4px 0 var(--panel-border-deep)",
      "inner-highlight": "inset 0 2px 0 rgba(255,255,255,0.7)",
      "inner-border": "2px solid rgba(255,255,255,0.5), inset 4px"
    },
    "button": {
      "border-bottom": "5px solid [darker]",
      "shine": "linear-gradient(180deg, rgba(255,255,255,0.45) 0%, transparent 50%)",
      "pressed-offset": "translateY(3px), border-bottom: 2px"
    },
    "badge": {
      "border": "3px solid [darker]",
      "bottom-bar": "0 3px 0 [darkest]",
      "shine": "radial-gradient at top, rgba(255,255,255,0.5)"
    },
    "progress": {
      "track-inset": "inset 0 3px 6px rgba(0,0,0,0.25)",
      "fill-shine": "linear-gradient(180deg, rgba(255,255,255,0.4) 0%, transparent 60%)"
    }
  },

  "animation": {
    "duration": {
      "instant": "60ms",
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms",
      "emphasis": "800ms"
    },
    "easing": {
      "bounce": "cubic-bezier(0.68, -0.55, 0.27, 1.55)",
      "ease-out": "cubic-bezier(0.0, 0.0, 0.2, 1.0)",
      "ease-in-out": "cubic-bezier(0.4, 0.0, 0.2, 1.0)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1.0)",
      "decelerate": "cubic-bezier(0.0, 0.0, 0.0, 1.0)"
    },
    "game": {
      "charge-fill": { "duration": "1200ms", "easing": "ease-out" },
      "ring-launch": { "duration": "400ms", "easing": "spring" },
      "hit-pop": { "duration": "300ms", "easing": "bounce" },
      "score-rise": { "duration": "600ms", "easing": "decelerate" },
      "combo-pulse": { "duration": "150ms", "easing": "ease-out", "repeat": 2 },
      "miss-fade": { "duration": "500ms", "easing": "ease-out" },
      "phase-transition": { "duration": "800ms", "easing": "ease-in-out" },
      "star-spin": { "duration": "400ms", "easing": "bounce" },
      "button-press": { "duration": "100ms", "easing": "ease-out" }
    }
  }
}
