[gd_resource type="Resource" format=3]

# ===========================================================================
# Font Configuration Reference
# ===========================================================================
#
# This project uses two font families:
#
# 1. LuckiestGuy-Regular.ttf  (Display / HUD / Scores / Headlines)
#    - Use for: score numbers, phase titles, hit feedback text, button labels
#    - Sizes: 42px (hit feedback), 32px (phase title), 28px (score), 22px (HUD)
#
# 2. Fredoka-Medium.ttf  (Body / UI / Labels / Captions)
#    - Weight: Medium (500)
#    - Use for: card names, stat captions, instructions, subtitles
#    - Sizes: 18px (body), 14px (subtitle), 12px (caption), 10px (tiny)
#
# Both TTFs are included in this directory. Godot auto-imports on project open.
#
# To apply globally in Project Settings:
#   gui/theme/custom_font = res://common/ui/fonts/Fredoka-Medium.ttf
#
# To load in GDScript:
#   var display_font = preload("res://common/ui/fonts/LuckiestGuy-Regular.ttf")
#   var body_font = preload("res://common/ui/fonts/Fredoka-Medium.ttf")
#
# ===========================================================================

[resource]
