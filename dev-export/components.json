{
  "$schema": "farm-ring-toss-components/1.0",
  "meta": {
    "game": "Farm Ring Toss",
    "engine": "Godot 4.3+ / C# (.NET 8)",
    "tokens_ref": "ui_tokens.gd",
    "total_components": 13
  },
  "components": [
    {
      "id": 2,
      "name": "ProgressBar",
      "path": "res://common/ui/scenes/progress_bar.tscn",
      "category": "common",
      "purpose": "Top progress bar showing session structure. Dynamically generates milestones from action plan.",
      "tree": {
        "root": "TotalProgress:Control",
        "children": ["Track:Panel", "Fill:Panel", "Milestones:Control > M1..MN:PanelContainer"]
      },
      "style": {
        "track_bg": "#FFF5D6",
        "track_border": "4px solid #C8A848",
        "track_shadow": "0 5px 0 #8B6A20",
        "track_radius": 24,
        "track_height": 54,
        "track_width": 960,
        "fill_gradient": "#7edb66 → #ffe064 → #ff9e37",
        "milestone_action_size": 42,
        "milestone_hand_size": 33,
        "milestone_action_done": "#6EC531 border #4A9B1E shadow #2B5E10",
        "milestone_hand_done": "#55C9C9 border #3AA shadow #288",
        "milestone_action_pending": "#e8dfc8 border #C8A848",
        "milestone_hand_pending": "#d8f0f0 border #8cc"
      },
      "logic": {
        "description": "Milestones are generated at runtime from the session's action_plan array. Each action adds a green 'action' circle. If that action requires_hand_switch, a teal 'hand' circle follows it (meaning: repeat this action with the other hand). Milestones are evenly spaced across the track.",
        "input": "action_plan: Array[{action_id: String, requires_hand_switch: bool}]",
        "milestone_generation": [
          "For each action in action_plan:",
          "  1. Add ACTION milestone (green, 42px)",
          "  2. If action.requires_hand_switch AND this is not the last segment:",
          "     Add HAND milestone (teal, 33px)",
          "Total milestones = len(actions) + count(hand_switches)"
        ],
        "fill_logic": "Fill width = (completed_milestones / total_milestones) * track_width. Gradient always starts from left edge.",
        "state_transitions": "When a milestone is completed: change from pending style to done style + show SVG checkmark. Animate with tween_bounce.",
        "examples": [
          "3 actions all single-arm → [Action, Hand, Action, Hand, Action] = 5 milestones",
          "4 actions, 2 bilateral → [Action, Hand, Action, Action, Hand, Action] = 6 milestones",
          "2 actions no hand switch (e.g. t-bar, squat) → [Action, Action] = 2 milestones"
        ]
      },
      "exports": {
        "action_plan": { "type": "Array", "default": [], "description": "Array of {action_id, requires_hand_switch} from session config" }
      },
      "signals": ["milestone_completed(index: int)", "all_milestones_done"]
    },
    {
      "id": 3,
      "name": "ActionCard",
      "path": "res://common/ui/action_card.tscn",
      "category": "common",
      "purpose": "Left-side exercise card: name tab + live MotionFeedbackPanel (athlete sprite with ROM/COP/speed overlays) + optional hand-switch pill + rep progress",
      "tree": {
        "root": "ActionCard:PanelContainer",
        "children": [
          "VBox > NameTab:Panel > NameLabel",
          "VBox > MotionFeedbackPanel:Control (embedded — replaces static IconArea; contains AthleteFrame + RomPathOverlay + CopPanel + RomMarker + DirectionArrow)",
          "VBox > HandPill:Panel (conditional)",
          "VBox > RepBlocks:HBox + CountLabel"
        ]
      },
      "style": {
        "panel": "cream panel (#FFF5D6, 5px border #8B6A20, shadow 6px #5A4010, RADIUS 28)",
        "panel_size": "352×576",
        "name_tab_bg": "COLOR_GREEN",
        "name_tab_border": "3px COLOR_GREEN_DARK",
        "name_tab_radius": 14,
        "name_tab_padding": "8px 28px",
        "name_font": "FONT_FAMILY_DISPLAY",
        "name_size": 30,
        "name_color": "white, text-shadow 0 3px 0 GREEN_DEEP",
        "motion_feedback_area": "fills IconArea slot, aspect-ratio 2:3, border 3px #a8c890, bg #e8f4dc, radius 16, clip_children = true. Contains the full MotionFeedbackPanel scene (athlete frames + ROM path + COP + marker + arrow) scaled to fit within the card.",
        "hand_pill_bg": "COLOR_BLUE (#55C9C9)",
        "hand_pill_border": "3px #3AA",
        "hand_pill_shadow": "3px #288",
        "hand_pill_radius": 99,
        "hand_pill_font_size": 22,
        "hand_pill_visibility": "ONLY visible during hand-switch phase, hidden otherwise",
        "rep_block_size": "20×24px, radius 5",
        "rep_block_done": "COLOR_GOLD border #B89800",
        "rep_block_pending": "#E8DFC0 border #B8AE98",
        "rep_count_font": "FONT_FAMILY_DISPLAY",
        "rep_count_size": 30,
        "rep_count_color": "COLOR_TEXT_DARK"
      },
      "logic": {
        "description": "The ActionCard embeds a MotionFeedbackPanel instance directly in place of the old static IconArea. The motion panel shows the live athlete sprite animation with ROM path overlay, speed zone, COP panel, marker dot, and direction arrow — all rendered within the card's clipped area. The COP sub-panel renders at the bottom portion of the motion feedback area (its position is defined in motion_feedback_config.json per exercise).",
        "motion_feedback_embedding": "ActionCard instantiates motion_feedback.tscn as a child, scaled to fit the 2:3 aspect area. The motion panel's internal 900×580 coordinate space is uniformly scaled down to fit the card width (~306px usable). All overlay positions (ROM points, COP center/size, athlete rect) are defined in motion_feedback_config.json and scale proportionally."
      },
      "exports": {
        "action_name": { "type": "String", "default": "KETTLEBELL SWING" },
        "action_key": { "type": "String", "default": "row", "description": "Key into motion_feedback_config.json actions dict — drives which athlete frames, ROM path, COP config, and speed profile to use" },
        "hand_side": { "type": "String", "default": "LEFT", "enum": ["LEFT", "RIGHT", "BOTH"] },
        "total_reps": { "type": "int", "default": 8 },
        "is_hand_switch_phase": { "type": "bool", "default": false }
      },
      "signals": ["card_shown", "card_hidden"],
      "animations": {
        "card_shown": "slide-in from left, 300ms ease-out",
        "hand_pill_show": "fade-in 200ms when is_hand_switch_phase becomes true"
      }
    },
