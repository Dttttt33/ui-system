          "perfect": { "color": "COLOR_PERFECT (#FFD700)", "size": 84, "shadow": "0 5px 0 #B89800" },
          "miss": { "color": "#A89878", "size": 52, "shadow": "0 3px 0 rgba(0,0,0,0.15)" },
          "combo": { "color": "COLOR_COMBO (#E8453A)", "size": 96, "shadow": "0 5px 0 RED_DEEP" }
        }
