[gd_resource type="Resource" format=3]

# =============================================================================
# Individual StyleBox exports — import these by ID in your scenes
# Use: preload("res://common/ui/theme/styleboxes.tres").panel_normal
# Or reference them from ui_theme.tres
# =============================================================================
#
# This file documents the exact StyleBox configurations.
# In practice, use ui_theme.tres which bundles them all.
# This file exists as a reference for scene-specific overrides.
#
# PANEL STYLES:
#   panel_normal — cream panel, gold border 4px, bottom bar 4px, radius 24
#   score_panel — smaller cream panel, 3px border, radius 14
#
# BUTTON STYLES:
#   button_normal — green, 3px border, 5px bottom, radius 14
#   button_pressed — green, 3px border, 0px bottom (pressed down 3px)
#   button_amber_normal — amber variant
#   button_red_normal — red variant
#
# PILL/BADGE STYLES:
#   pill_green — rep counter, hand badges
#   pill_cyan — hand switch indicator
#
# TRACK STYLES:
#   track_bg — progress/charge bar track (inset look)
#
# STAT CARD STYLES:
#   stat_card_green — end panel score stat
#   stat_card_amber — end panel best-hit stat
#   stat_card_red — end panel golden stat
#
# DEPTH RULES (apply to ALL above):
#   - border_width_bottom = normal_border + depth_bar
#   - NO shadow_size for soft shadows (only inset for tracks)
#   - Pressed state: border_width_bottom = normal_border (loses the bar)
#   - Pressed content_margin_top += 3 (visual push down)

[resource]
