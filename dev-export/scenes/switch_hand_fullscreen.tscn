anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.55)

# Centered text: "SWITCH TO LEFT HAND" (40px, white, shadow down 3px)
