# ===========================================================================
# SwitchHandFullscreen — Fullscreen overlay on 1920×1080
# CanvasLayer 15 (above game, below rainbow)
# Dark dim (55% black) + centered big white text with shadow
# Text area: centered, 800×80
# Position: x:560 y:500 → x:1360 y:580
# ===========================================================================

[node name="SwitchHandFullscreen" type="CanvasLayer"]
layer = 15

# Fullscreen dim overlay
[node name="Overlay" type="ColorRect" parent="."]
