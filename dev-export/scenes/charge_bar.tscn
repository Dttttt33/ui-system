[gd_scene load_steps=4 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]
[ext_resource type="Shader" path="res://common/ui/shaders/progress_fill.gdshader" id="shader_fill"]

# ===========================================================================
# ChargeBar — Bottom-center of HUD on 1920×1080
# Position: x:800 y:940 → x:1120 y:990 (320×50 including label)
# Track: 320×22px, warm grey bg, pill radius
# Fill: shader-based green→yellow→orange gradient
# ===========================================================================

# Track bg: warm grey, border simulating inset
# HTML: bg #D4C4A0, border 3px #8B7A5A
[sub_resource type="StyleBoxFlat" id="track"]
bg_color = Color(0.831, 0.788, 0.659, 1)
border_color = Color(0.545, 0.478, 0.353, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Fill shader material
[sub_resource type="ShaderMaterial" id="fill_mat"]
shader = ExtResource("shader_fill")
shader_parameter/color_start = Color(0.494, 0.859, 0.400, 1)
shader_parameter/color_mid = Color(1.0, 0.878, 0.392, 1)
shader_parameter/color_end = Color(1.0, 0.620, 0.216, 1)
shader_parameter/color_full_start = Color(0.961, 0.722, 0.0, 1)
shader_parameter/color_full_end = Color(1, 0.843, 0, 1)
shader_parameter/progress = 0.6
shader_parameter/is_full = false
shader_parameter/shine_height = 0.45
shader_parameter/shine_opacity = 0.45

# Root: bottom-center
[node name="ChargeBar" type="VBoxContainer"]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -160.0
offset_top = -90.0
offset_right = 160.0
offset_bottom = -50.0
grow_horizontal = 2
grow_vertical = 0
theme_override_constants/separation = 4

# "CHARGE" label above bar
[node name="Label" type="Label" parent="."]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 0.3)
theme_override_constants/shadow_offset_y = 2
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 12
text = "CHARGE"
horizontal_alignment = 1

# Track panel: 320×22
[node name="Track" type="PanelContainer" parent="."]
layout_mode = 2
custom_minimum_size = Vector2(320, 22)
theme_override_styles/panel = SubResource("track")

# Fill: ColorRect with shader material (progress controlled by script)
[node name="Fill" type="ColorRect" parent="Track"]
layout_mode = 2
material = SubResource("fill_mat")
