[gd_scene load_steps=4 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]
[ext_resource type="Shader" path="res://common/ui/shaders/directional_glow.gdshader" id="shader_glow"]

# ===========================================================================
# FoxWarning — Fullscreen overlay on 1920×1080
# Directional amber edge glow (left or right) + centered cream pill
# Pill size: 320×68, centered at (960, 540)
# Pill position: x:800 y:506 → x:1120 y:574
# ===========================================================================

[sub_resource type="ShaderMaterial" id="left_glow"]
shader = ExtResource("shader_glow")
shader_parameter/glow_color = Color(0.961, 0.651, 0.137, 1.0)
shader_parameter/intensity = 0.35
shader_parameter/pulse_speed = 1.4
shader_parameter/direction = 1

# Cream pill with gold border + bottom shadow
# HTML: bg #FFF5D6, border 4px #C8A848, box-shadow 0 5px 0 #8B6A20, radius pill
[sub_resource type="StyleBoxFlat" id="pill"]
bg_color = Color(1.0, 0.961, 0.839, 1)
border_color = Color(0.784, 0.659, 0.282, 1)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
shadow_color = Color(0.545, 0.416, 0.125, 1)
shadow_size = 5
shadow_offset = Vector2(0, 3)
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999
content_margin_left = 28.0
content_margin_top = 12.0
content_margin_right = 28.0
content_margin_bottom = 12.0

# Root: fullscreen
[node name="FoxWarning" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

# Directional glow: fullscreen shader overlay
[node name="DirectionalGlow" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
material = SubResource("left_glow")
color = Color(1, 1, 1, 1)

# Centered pill: fox icon + "WATCH OUT!"
[node name="Pill" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -160.0
offset_top = -34.0
offset_right = 160.0
offset_bottom = 34.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("pill")

[node name="HBox" type="HBoxContainer" parent="Pill"]
layout_mode = 2
theme_override_constants/separation = 14
alignment = 1

# Fox icon: 44×44 TextureRect (load fox_icon.png)
[node name="FoxIcon" type="TextureRect" parent="Pill/HBox"]
custom_minimum_size = Vector2(44, 44)
layout_mode = 2

[node name="Label" type="Label" parent="Pill/HBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.290, 0.216, 0.157, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 0.1)
theme_override_constants/shadow_offset_y = 2
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 26
text = "WATCH OUT!"
