[gd_scene load_steps=2 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]

# ===========================================================================
# ScorePopup — Floats up from hit position toward ScoreHUD
# Size: 120×60 (spawned dynamically at hit world→screen position)
# Animation: rises 40px while fading out over 600ms
# ===========================================================================

[node name="ScorePopup" type="Control"]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -60.0
offset_top = -30.0
offset_right = 60.0
offset_bottom = 30.0
grow_horizontal = 2
grow_vertical = 2

# Shadow text: offset 2px right, 3px down
[node name="Shadow" type="Label" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 2.0
offset_top = 3.0
theme_override_colors/font_color = Color(0.290, 0.608, 0.118, 0.5)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 32
text = "+240"
horizontal_alignment = 1
vertical_alignment = 1

# Main value text: green with white outline glow
[node name="Value" type="Label" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_colors/font_color = Color(0.431, 0.773, 0.192, 1)
theme_override_colors/font_shadow_color = Color(0.169, 0.369, 0.063, 0.5)
theme_override_constants/shadow_offset_y = 3
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 32
text = "+240"
horizontal_alignment = 1
vertical_alignment = 1
