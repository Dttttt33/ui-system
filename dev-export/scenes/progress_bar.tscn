[gd_scene load_steps=7 format=3]

[ext_resource type="Theme" path="res://theme/ui_theme.tres" id="theme"]
[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]
[ext_resource type="Shader" path="res://common/ui/shaders/progress_fill.gdshader" id="shader_fill"]

# ===========================================================================
# ProgressBar — Top-center of HUD on 1920×1080
# Position: x:640–1280 (centered), y:12–48
# Actual size: 640×36
# Milestones extend ±8px beyond track vertically
# ===========================================================================

# Track = cream panel style
# HTML: bg #FFF5D6, border 4px #C8A848, box-shadow 0 5px 0 #8B6A20
[sub_resource type="StyleBoxFlat" id="track"]
bg_color = Color(1.0, 0.961, 0.839, 1)
border_color = Color(0.784, 0.659, 0.282, 1)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
shadow_color = Color(0.545, 0.416, 0.125, 1)
shadow_size = 5
shadow_offset = Vector2(0, 3)
corner_radius_top_left = 16
corner_radius_top_right = 16
corner_radius_bottom_left = 16
corner_radius_bottom_right = 16

# Fill shader: three-stop green→yellow→orange
[sub_resource type="ShaderMaterial" id="fill_mat"]
shader = ExtResource("shader_fill")
shader_parameter/color_start = Color(0.494, 0.859, 0.400, 1)
shader_parameter/color_mid = Color(1.0, 0.878, 0.392, 1)
shader_parameter/color_end = Color(1.0, 0.620, 0.216, 1)
shader_parameter/color_full_start = Color(0.961, 0.722, 0.0, 1)
shader_parameter/color_full_end = Color(1, 0.843, 0, 1)
shader_parameter/progress = 0.4
shader_parameter/is_full = false
shader_parameter/shine_height = 0.3
shader_parameter/shine_opacity = 0.45

# Milestone done: green action (28×28)
# HTML: bg #6EC531, border 3px #4A9B1E, box-shadow 0 3px 0 #2B5E10
[sub_resource type="StyleBoxFlat" id="ms_action_done"]
bg_color = Color(0.431, 0.773, 0.192, 1)
border_color = Color(0.290, 0.608, 0.118, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
shadow_color = Color(0.169, 0.369, 0.063, 1)
shadow_size = 3
shadow_offset = Vector2(0, 2)
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Milestone done: teal hand (22×22)
# HTML: bg #55c9c9, border 3px #3aa, box-shadow 0 2px 0 #288
[sub_resource type="StyleBoxFlat" id="ms_hand_done"]
bg_color = Color(0.333, 0.788, 0.788, 1)
border_color = Color(0.200, 0.667, 0.667, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
shadow_color = Color(0.157, 0.502, 0.502, 1)
shadow_size = 2
shadow_offset = Vector2(0, 1)
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Milestone pending: action (28×28, muted)
[sub_resource type="StyleBoxFlat" id="ms_action_pending"]
bg_color = Color(0.910, 0.875, 0.784, 1)
border_color = Color(0.784, 0.659, 0.282, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Root: centered top, 640×36 track + milestone overflow
# Absolute on 1920×1080: x:640 y:12 → x:1280 y:48
[node name="ProgressBar" type="Control"]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -320.0
offset_top = 12.0
offset_right = 320.0
offset_bottom = 48.0
grow_horizontal = 2

# Track panel: fills the whole control
[node name="Track" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_styles/panel = SubResource("track")

# Fill: inside track, clipped, 4px inset on all sides
[node name="FillClip" type="Control" parent="Track"]
layout_mode = 2
clip_children = 1

[node name="Fill" type="ColorRect" parent="Track/FillClip"]
layout_mode = 1
offset_left = 4.0
offset_top = 4.0
offset_right = 260.0
offset_bottom = 28.0
material = SubResource("fill_mat")

# Milestones: absolute positioned over track
# Spacing: evenly across 640px width, 6 milestones
# x positions: ~76, 182, 288, 396, 502, 560 (distributed)
[node name="Milestones" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

# M1: Action done (green, 28×28) — x:76
[node name="M1" type="PanelContainer" parent="Milestones"]
custom_minimum_size = Vector2(28, 28)
layout_mode = 1
offset_left = 76.0
offset_top = -4.0
offset_right = 104.0
offset_bottom = 24.0
theme_override_styles/panel = SubResource("ms_action_done")

[node name="Check" type="Label" parent="Milestones/M1"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 12
text = "✓"
horizontal_alignment = 1
vertical_alignment = 1

