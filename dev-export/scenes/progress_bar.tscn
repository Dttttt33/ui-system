corner_radius_bottom_right = 999

# Root: centered top, 640×36
# y:24 (moved down from edge per user feedback)
[node name="ProgressBar" type="Control"]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -320.0
offset_top = 24.0
offset_right = 320.0
offset_bottom = 60.0
grow_horizontal = 2

# Track panel: fills the whole control (640×36)
[node name="Track" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_styles/panel = SubResource("track")

# Fill: inside track, clipped, 4px inset on all sides
[node name="FillClip" type="Control" parent="Track"]
layout_mode = 2
clip_children = 1

[node name="Fill" type="ColorRect" parent="Track/FillClip"]
layout_mode = 1
offset_left = 4.0
offset_top = 4.0
offset_right = 260.0
offset_bottom = 28.0
material = SubResource("fill_mat")

# Milestones: vertically centered, evenly spaced
# 6 milestones across 640px with 14px edge padding
# x: 14, 136, 258, 380, 502, 612 (center of each dot)
# For 28px dot: left = x - 14, top = (36-28)/2 = 4
# For 22px dot: left = x - 11, top = (36-22)/2 = 7
[node name="Milestones" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

# M1: Action done (green, 28×28) — center x:14 → left:0, top:4
[node name="M1" type="PanelContainer" parent="Milestones"]
custom_minimum_size = Vector2(28, 28)
layout_mode = 1
offset_left = 0.0
offset_top = 4.0
offset_right = 28.0
offset_bottom = 32.0
theme_override_styles/panel = SubResource("ms_action_done")

[node name="Check" type="Label" parent="Milestones/M1"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 12
text = "✓"
horizontal_alignment = 1
vertical_alignment = 1

