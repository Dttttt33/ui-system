corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Root: centered top, 960×54
# y:12 (full-width centered)
[node name="ProgressBar" type="Control"]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -480.0
offset_top = 12.0
offset_right = 480.0
offset_bottom = 66.0
grow_horizontal = 2

# Track panel: fills the whole control (640×36)
[node name="Track" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_styles/panel = SubResource("track")

# Fill: inside track, clipped, 4px inset on all sides
[node name="FillClip" type="Control" parent="Track"]
layout_mode = 2
clip_children = 1

[node name="Fill" type="ColorRect" parent="Track/FillClip"]
layout_mode = 1
offset_left = 4.0
offset_top = 4.0
offset_right = 260.0
offset_bottom = 28.0
material = SubResource("fill_mat")

# Milestones: vertically centered, evenly spaced
# 6 milestones across 960px with 20px edge padding
# x: 20, 204, 388, 572, 756, 940 (center of each dot)
# For 42px dot: left = x - 21, top = (54-42)/2 = 6
# For 33px dot: left = x - 16.5 ≈ 16, top = (54-33)/2 ≈ 10
[node name="Milestones" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

# M1: Action done (green, 42×42) — center x:20 → left:-1, top:6
[node name="M1" type="PanelContainer" parent="Milestones"]
custom_minimum_size = Vector2(42, 42)
layout_mode = 1
offset_left = -1.0
offset_top = 6.0
offset_right = 41.0
offset_bottom = 48.0
theme_override_styles/panel = SubResource("ms_action_done")

[node name="Check" type="Label" parent="Milestones/M1"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 16
text = "✓"
horizontal_alignment = 1
vertical_alignment = 1

