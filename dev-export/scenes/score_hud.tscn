[gd_scene load_steps=5 format=3]

[ext_resource type="Theme" path="res://theme/ui_theme.tres" id="theme"]
[ext_resource type="FontFile" path="res://common/ui/fonts/LuckiestGuy-Regular.ttf" id="font_display"]

# ===========================================================================
# ScoreHUD — Top-right of HUD on 1920×1080
# Position: 12px from right edge, 24px from top
# Structure: cream panel wrapper (auto-width), two side-by-side badges
# HTML: display:inline-flex;gap:10px;padding:12px 18px;
#        background:#FFF5D6; border:4px solid #C8A848; border-radius:18px;
#        box-shadow:0 5px 0 #8B6A20
#
# Badge layout:
#   SCORE badge (amber) + CAUGHT badge (green)
#   Each badge: border-radius:12px, padding:6px 14px
#   Caption: 9px Luckiest Guy, Value: 26px Luckiest Guy
# ===========================================================================

# Outer wrapper = cream panel
# HTML: bg #FFF5D6, border 4px #C8A848, box-shadow 0 5px 0 #8B6A20
[sub_resource type="StyleBoxFlat" id="outer"]
bg_color = Color(1.0, 0.961, 0.839, 1)
border_color = Color(0.784, 0.659, 0.282, 1)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
shadow_color = Color(0.545, 0.416, 0.125, 1)
shadow_size = 5
shadow_offset = Vector2(0, 3)
corner_radius_top_left = 18
corner_radius_top_right = 18
corner_radius_bottom_left = 18
corner_radius_bottom_right = 18
content_margin_left = 18.0
content_margin_top = 12.0
content_margin_right = 18.0
content_margin_bottom = 12.0

# Score badge = amber
# HTML: bg #F5A623, border 3px #D4891A, box-shadow 0 4px 0 #A06810
[sub_resource type="StyleBoxFlat" id="badge_amber"]
bg_color = Color(0.961, 0.651, 0.137, 1)
border_color = Color(0.831, 0.537, 0.102, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
shadow_color = Color(0.627, 0.408, 0.063, 1)
shadow_size = 4
shadow_offset = Vector2(0, 2)
corner_radius_top_left = 12
corner_radius_top_right = 12
corner_radius_bottom_left = 12
corner_radius_bottom_right = 12
content_margin_left = 14.0
content_margin_top = 6.0
content_margin_right = 14.0
content_margin_bottom = 6.0

# Caught badge = green
# HTML: bg #6EC531, border 3px #4A9B1E, box-shadow 0 4px 0 #2B5E10
[sub_resource type="StyleBoxFlat" id="badge_green"]
bg_color = Color(0.431, 0.773, 0.192, 1)
border_color = Color(0.290, 0.608, 0.118, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
shadow_color = Color(0.169, 0.369, 0.063, 1)
shadow_size = 4
shadow_offset = Vector2(0, 2)
corner_radius_top_left = 12
corner_radius_top_right = 12
corner_radius_bottom_left = 12
corner_radius_bottom_right = 12
content_margin_left = 14.0
content_margin_top = 6.0
content_margin_right = 14.0
content_margin_bottom = 6.0

# Position: top-right, 24px from right edge, 24px from top
# Wider (296px) for bigger badges
[node name="ScoreHUD" type="PanelContainer"]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -320.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = 130.0
grow_horizontal = 0
size_flags_horizontal = 4
theme_override_styles/panel = SubResource("outer")

[node name="HBox" type="HBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 10
alignment = 1

# Amber SCORE badge
[node name="ScoreBadge" type="PanelContainer" parent="HBox"]
layout_mode = 2
theme_override_styles/panel = SubResource("badge_amber")

[node name="VBox" type="VBoxContainer" parent="HBox/ScoreBadge"]
layout_mode = 2
alignment = 1

[node name="Caption" type="Label" parent="HBox/ScoreBadge/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.290, 0.216, 0.157, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 14
text = "SCORE"
horizontal_alignment = 1

[node name="Value" type="Label" parent="HBox/ScoreBadge/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.290, 0.216, 0.157, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 36
text = "480"
horizontal_alignment = 1

# Green CAUGHT badge
[node name="CaughtBadge" type="PanelContainer" parent="HBox"]
layout_mode = 2
theme_override_styles/panel = SubResource("badge_green")

[node name="VBox" type="VBoxContainer" parent="HBox/CaughtBadge"]
layout_mode = 2
alignment = 1

[node name="Caption" type="Label" parent="HBox/CaughtBadge/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 14
text = "CAUGHT"
horizontal_alignment = 1

[node name="Value" type="Label" parent="HBox/CaughtBadge/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 36
text = "6"
horizontal_alignment = 1
