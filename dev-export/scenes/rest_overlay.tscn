[gd_scene load_steps=3 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]

# ===========================================================================
# RestOverlay — Fullscreen pause overlay on 1920×1080
# CanvasLayer 12 (above game HUD)
# Dark dim (40%) + centered teal-bordered cream card
# Card size: 400×240, centered at (960, 540)
# Card position: x:760 y:420 → x:1160 y:660
# ===========================================================================

# Card: cream bg, teal border + shadow
# HTML: bg #FFF5D6, border 5px #55c9c9, box-shadow 0 7px 0 #288080
[sub_resource type="StyleBoxFlat" id="rest_card"]
bg_color = Color(1, 0.96, 0.84, 1)
border_color = Color(0.333, 0.788, 0.788, 1)
border_width_left = 5
border_width_top = 5
border_width_right = 5
border_width_bottom = 5
shadow_color = Color(0.157, 0.502, 0.502, 1)
shadow_size = 7
shadow_offset = Vector2(0, 4)
corner_radius_top_left = 24
corner_radius_top_right = 24
corner_radius_bottom_left = 24
corner_radius_bottom_right = 24
content_margin_left = 32.0
content_margin_top = 28.0
content_margin_right = 32.0
content_margin_bottom = 28.0

# Green button for "SKIP"
[sub_resource type="StyleBoxFlat" id="skip_btn"]
bg_color = Color(0.431, 0.773, 0.192, 1)
border_color = Color(0.290, 0.608, 0.118, 1)
border_width_bottom = 5
shadow_color = Color(0.169, 0.369, 0.063, 1)
shadow_size = 3
shadow_offset = Vector2(0, 2)
corner_radius_top_left = 14
corner_radius_top_right = 14
corner_radius_bottom_left = 14
corner_radius_bottom_right = 14
content_margin_left = 20.0
content_margin_top = 12.0
content_margin_right = 20.0
content_margin_bottom = 12.0

[node name="RestOverlay" type="CanvasLayer"]
layer = 12

# Fullscreen dim
[node name="Dim" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.4)

# Centered card: 400×240
[node name="Card" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -120.0
offset_right = 200.0
offset_bottom = 120.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = SubResource("rest_card")

[node name="VBox" type="VBoxContainer" parent="Card"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 12

# "REST" title in teal
[node name="Title" type="Label" parent="Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.333, 0.788, 0.788, 1)
theme_override_colors/font_shadow_color = Color(0.180, 0.510, 0.510, 1)
theme_override_constants/shadow_offset_y = 3
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 32
text = "REST"
horizontal_alignment = 1

# Timer: "0:15"
[node name="Timer" type="Label" parent="Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.290, 0.216, 0.157, 1)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 48
text = "0:15"
horizontal_alignment = 1

# Subtitle: "Shake it off!"
[node name="Subtitle" type="Label" parent="Card/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.290, 0.216, 0.157, 0.7)
theme_override_font_sizes/font_size = 16
text = "Shake it off!"
horizontal_alignment = 1

# Skip button: green, 180×44
[node name="SkipBtn" type="Button" parent="Card/VBox"]
layout_mode = 2
size_flags_horizontal = 4
custom_minimum_size = Vector2(180, 44)
theme_override_font_sizes/font_size = 16
text = "SKIP"

# Button shine highlight
[node name="BtnShine" type="ColorRect" parent="Card/VBox/SkipBtn"]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_left = 6.0
offset_top = 3.0
offset_right = -6.0
offset_bottom = 16.0
color = Color(1, 1, 1, 0.4)
