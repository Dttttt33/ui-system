[gd_scene load_steps=3 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]

# ===========================================================================
# TimerHUD — Top-right area (alternative to ScoreHUD for timed modes)
# Position: x:1748 y:20 → x:1908 y:72 (160×52)
# Amber badge with clock icon + time value
# ===========================================================================

# HTML: bg #F5A623, border 3px #D4891A, box-shadow 0 4px 0 #A06810
[sub_resource type="StyleBoxFlat" id="timer_panel"]
bg_color = Color(0.961, 0.651, 0.137, 1)
border_color = Color(0.831, 0.537, 0.102, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
shadow_color = Color(0.627, 0.408, 0.063, 1)
shadow_size = 4
shadow_offset = Vector2(0, 2)
corner_radius_top_left = 14
corner_radius_top_right = 14
corner_radius_bottom_left = 14
corner_radius_bottom_right = 14
content_margin_left = 16.0
content_margin_top = 6.0
content_margin_right = 16.0
content_margin_bottom = 6.0

# Shine (button_shine.gdshader could be used here too)
[sub_resource type="StyleBoxFlat" id="shine_rect"]
bg_color = Color(1, 1, 1, 0.35)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_left = 8
corner_radius_bottom_right = 8

[node name="TimerHUD" type="PanelContainer"]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -172.0
offset_top = 20.0
offset_right = -12.0
offset_bottom = 72.0
grow_horizontal = 0
theme_override_styles/panel = SubResource("timer_panel")

[node name="HBox" type="HBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 10
alignment = 1

[node name="Icon" type="TextureRect" parent="HBox"]
custom_minimum_size = Vector2(24, 24)
layout_mode = 2

[node name="Value" type="Label" parent="HBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(0.627, 0.412, 0.063, 1)
theme_override_constants/shadow_offset_y = 3
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 28
text = "2:45"

# Top shine highlight
[node name="Shine" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_left = 6.0
offset_top = 3.0
offset_right = -6.0
offset_bottom = 16.0
color = Color(1, 1, 1, 0.35)
