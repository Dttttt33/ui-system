[gd_scene load_steps=3 format=3]

[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]

# ===========================================================================
# ReturnRhythmBar — Bottom-center of HUD on 1920×1080
# Position: x:760 y:980 → x:1160 y:1040 (400×60 including result label)
# Track: 400×20px, warm grey, pill radius
# Ideal zone: green @ 50% opacity, positioned at 40-70% of track width
# Cursor: 6px wide amber bar, animated left→right
# ===========================================================================

# Track style
[sub_resource type="StyleBoxFlat" id="track_style"]
bg_color = Color(0.831, 0.792, 0.627, 1)
border_color = Color(0.545, 0.478, 0.353, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Ideal zone: green @ 50% opacity
[sub_resource type="StyleBoxFlat" id="ideal_zone"]
bg_color = Color(0.431, 0.773, 0.192, 0.5)
corner_radius_top_left = 999
corner_radius_top_right = 999
corner_radius_bottom_left = 999
corner_radius_bottom_right = 999

# Root: bottom-center
[node name="ReturnRhythmBar" type="VBoxContainer"]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -200.0
offset_top = -60.0
offset_right = 200.0
offset_bottom = -20.0
grow_horizontal = 2
grow_vertical = 0
theme_override_constants/separation = 6

# Track: 400×20
[node name="Track" type="PanelContainer" parent="."]
layout_mode = 2
custom_minimum_size = Vector2(400, 20)
theme_override_styles/panel = SubResource("track_style")

# Ideal zone: 40%–70% of 400px = x:160 → x:280 (120px wide)
[node name="IdealZone" type="Panel" parent="Track"]
layout_mode = 1
offset_left = 160.0
offset_top = 2.0
offset_right = 280.0
offset_bottom = 18.0
theme_override_styles/panel = SubResource("ideal_zone")

# Cursor: 6px wide amber bar, full height of track
[node name="Cursor" type="ColorRect" parent="Track"]
layout_mode = 1
offset_left = 0.0
offset_top = 0.0
offset_right = 6.0
offset_bottom = 20.0
color = Color(0.961, 0.651, 0.137, 1)

# Result label: shown after timing attempt
[node name="ResultLabel" type="Label" parent="."]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 0.3)
theme_override_constants/shadow_offset_y = 2
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 14
text = ""
horizontal_alignment = 1
