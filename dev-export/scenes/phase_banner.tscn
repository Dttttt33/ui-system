[gd_scene load_steps=3 format=3]

[ext_resource type="Theme" path="res://theme/ui_theme.tres" id="theme"]
[ext_resource type="FontFile" path="res://assets/fonts/LuckiestGuy-Regular.ttf" id="font_display"]

# ===========================================================================
# PhaseBanner — Upper-center of viewport on 1920×1080
# Position: centered horizontally, y:100 (top area, below progress bar)
# Amber button style, centered, auto-fades after 2s
# Font sizes 2x per feedback: phase label 24px, title 48px
# ===========================================================================

# Amber button-style panel
# HTML: bg #F5A623, border 4px #D4891A, box-shadow 0 5px 0 #A06810
[sub_resource type="StyleBoxFlat" id="banner"]
bg_color = Color(0.961, 0.651, 0.137, 1)
border_color = Color(0.831, 0.537, 0.102, 1)
border_width_left = 4
border_width_top = 4
border_width_right = 4
border_width_bottom = 4
shadow_color = Color(0.627, 0.408, 0.063, 1)
shadow_size = 5
shadow_offset = Vector2(0, 3)
corner_radius_top_left = 16
corner_radius_top_right = 16
corner_radius_bottom_left = 16
corner_radius_bottom_right = 16
content_margin_left = 40.0
content_margin_top = 16.0
content_margin_right = 40.0
content_margin_bottom = 16.0

# Top-center area
[node name="PhaseBanner" type="PanelContainer"]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -300.0
offset_top = 100.0
offset_right = 300.0
offset_bottom = 220.0
grow_horizontal = 2
theme_override_styles/panel = SubResource("banner")

# Top shine highlight (HTML: white gradient 35% opacity, top 4px to 35% height)
[node name="Shine" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_left = 8.0
offset_top = 4.0
offset_right = -8.0
offset_bottom = 20.0
color = Color(1, 1, 1, 0.35)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 2

[node name="PhaseLabel" type="Label" parent="VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 0.85)
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 24
text = "PHASE 2 OF 3"
horizontal_alignment = 1

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_colors/font_shadow_color = Color(0, 0, 0, 0.2)
theme_override_constants/shadow_offset_y = 3
theme_override_fonts/font = ExtResource("font_display")
theme_override_font_sizes/font_size = 48
text = "CATCH THE FAR TARGETS!"
horizontal_alignment = 1
