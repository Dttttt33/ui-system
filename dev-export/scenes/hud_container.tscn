[gd_scene load_steps=1 format=3]

# ===========================================================================
# HUD Container — Layout zones on 1920×1080 viewport
# ===========================================================================
# All positions are in absolute pixels for 1920×1080.
# stretch_mode = canvas_items, aspect = keep (see project_settings.cfg)
# Safe area: 40px all edges. All elements inside Rect2(40, 40, 1840, 1000).
#
# REMOVED: BottomCenter (ChargeBar / ReturnRhythmBar no longer used)
#
# Layout map:
# ┌─ 40px safe area ──────────────────────────────────────────────────────────┐
# │                                                                           │
# │              ProgressBar (960w, centered)       ScoreHUD (384×154)        │
# │              x:480 y:40, 960×54                 x:1496 y:40              │
# │                                                                           │
# │  ActionCard         CenterArea (below progress bar)                      │
# │  x:40 y:252         x:580 y:120, 660×500                                │
# │  352×576            HitResult / MultiHit / PhaseBanner / Rainbow         │
# │  fonts 1.5x                                                              │
# │                                                                           │
# │  GoldenCountdown: 176×176, follows pumpkin (NOT in this container)       │
# │  BurstHint: CanvasLayer 9 (fullscreen edge glow)                         │
# │  SwitchHand: CanvasLayer 15 (fullscreen overlay)                         │
# │  EndPanel: CanvasLayer 20 (fullscreen modal)                             │
# │                                                                           │
# └───────────────────────────────────────────────────────────────────────────┘

[node name="HUDContainer" type="CanvasLayer"]
layer = 10

# --- TOP CENTER: ProgressBar zone ---
# Position: centered horizontally, 40px from top (safe area)
# Size: 960×54
[node name="TopCenter" type="Control" parent="."]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -480.0
offset_top = 40.0
offset_right = 480.0
offset_bottom = 94.0
grow_horizontal = 2

# --- TOP RIGHT: ScoreHUD zone ---
# Position: 40px from right edge (safe area), 40px from top
# Size: 384×154 (1.2x wide, 1.4x tall)
[node name="TopRight" type="Control" parent="."]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -424.0
offset_top = 40.0
offset_right = -40.0
offset_bottom = 194.0
grow_horizontal = 0

# --- LEFT: ActionCard zone ---
# Position: 40px from left (safe area), y:252
# Size: 352×576
# Fonts: 1.5x (name 30px, pill 22px, rep count 30px)
[node name="LeftCard" type="Control" parent="."]
anchors_preset = 0
offset_left = 40.0
offset_top = 252.0
offset_right = 392.0
offset_bottom = 828.0

# --- CENTER AREA: Transient feedback (below progress bar) ---
# Position: x:580 y:120
# Size: 660×500
# Contains: HitResultText, MultiHitResult, PhaseBanner, RainbowFullscreen
[node name="CenterArea" type="Control" parent="."]
anchors_preset = 0
offset_left = 580.0
offset_top = 120.0
offset_right = 1240.0
offset_bottom = 620.0

# --- FULLSCREEN overlays ---
# BurstHint: own CanvasLayer 9 (fullscreen amber edge glow, breathing 1.2s)
# SwitchHand: own CanvasLayer 15 (55% dim + 120px text, no subtitle)
# EndPanel: own CanvasLayer 20 (40% dim + 868×605 panel, space-evenly)
# RainbowFullscreen: own CanvasLayer 20 (15% white overlay + 104px rainbow text)
# GoldenCountdown: NOT in HUD — follows pumpkin Node3D world position (176×176)
