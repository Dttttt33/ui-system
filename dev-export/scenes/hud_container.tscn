[gd_scene load_steps=1 format=3]

# ===========================================================================
# HUD Container — Layout zones on 1920×1080 viewport
# ===========================================================================
# All positions are in absolute pixels for 1920×1080.
# stretch_mode = canvas_items, aspect = keep (see project_settings.cfg)
#
# Layout map:
# ┌────────────────────────────────────────────────────────────────────────┐
# │                    [TopCenter: ProgressBar]   [TopRight: ScoreHUD]     │
# │                     center, 640w              x:1600 y:24             │
# │                     y:24, h:36               296×106                  │
# │                                                                        │
# │                     [CenterTop: ComboCounter]                          │
# │                      center, 240w, y:80                                │
# │                                                                        │
# │ [LeftCard]           [Upper: HitResult / PhaseBanner]                  │
# │  x:24 y:250          center, 800×200, y:200                           │
# │  330×580                                                               │
# │                                                                        │
# │                     [BottomCenter: ChargeBar / RhythmBar]              │
# │                      center, 320w, y:940–990                           │
# └────────────────────────────────────────────────────────────────────────┘

[node name="HUDContainer" type="CanvasLayer"]
layer = 10

# --- TOP CENTER: ProgressBar zone ---
# Position: centered horizontally, 24px from top
# Size: 640×48 (bar is 36px tall, milestones extend ±8px)
[node name="TopCenter" type="Control" parent="."]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -320.0
offset_top = 24.0
offset_right = 320.0
offset_bottom = 72.0
grow_horizontal = 2

# --- TOP RIGHT: ScoreHUD zone ---
# Position: 24px from right edge, 24px from top
# Size: 296×106 (bigger badges)
[node name="TopRight" type="Control" parent="."]
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -320.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = 130.0
grow_horizontal = 0

# --- CENTER TOP: ComboCounter zone ---
# Position: centered horizontally, y:80 (below progress bar)
# Size: 240×70
[node name="CenterTop" type="Control" parent="."]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -120.0
offset_top = 80.0
offset_right = 120.0
offset_bottom = 150.0
grow_horizontal = 2

# --- LEFT: ActionCard zone ---
# Position: 24px from left, vertically centered (y: 250–830)
# Size: 330×580 (1.5x wider per feedback)
[node name="LeftCard" type="Control" parent="."]
anchors_preset = 4
anchor_top = 0.5
anchor_bottom = 0.5
offset_left = 24.0
offset_top = -290.0
offset_right = 354.0
offset_bottom = 290.0
grow_vertical = 2

# --- UPPER CENTER: Transient feedback (HitResult, PhaseBanner, MultiHit) ---
# Position: centered, upper area y:200
# Size: 800×200
[node name="UpperCenter" type="Control" parent="."]
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -400.0
offset_top = 200.0
offset_right = 400.0
offset_bottom = 400.0
grow_horizontal = 2

# --- BOTTOM CENTER: ChargeBar / ReturnRhythmBar ---
# Position: centered, 90px from bottom
# Size: 320×40
[node name="BottomCenter" type="Control" parent="."]
anchors_preset = 7
anchor_left = 0.5
anchor_top = 1.0
anchor_right = 0.5
anchor_bottom = 1.0
offset_left = -160.0
offset_top = -90.0
offset_right = 160.0
offset_bottom = -50.0
grow_horizontal = 2
grow_vertical = 0

# --- FULLSCREEN overlays (BurstHint, SwitchHand, RainbowFullscreen) ---
# Handled by their own CanvasLayer at higher layer indices
